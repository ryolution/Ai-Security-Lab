{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-security-lab.local/schemas/target.schema.json",
  "title": "AI Security Lab Target Configuration",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "type", "authorization", "connection", "capabilities", "limits"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+$"
    },
    "type": {
      "enum": [
        "openai-compatible",
        "ollama",
        "huggingface",
        "http-api",
        "rag-http",
        "agent-http",
        "mcp"
      ]
    },
    "authorization": {
      "type": "object",
      "required": ["confirmed"],
      "properties": {
        "confirmed": {
          "type": "boolean"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "connection": {
      "type": "object",
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "limits": {
      "type": "object",
      "additionalProperties": {
        "type": ["integer", "number", "string", "boolean"]
      }
    },
    "redaction": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "additional_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
